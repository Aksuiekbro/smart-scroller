{
  "manifest_version": 3,
  "name": "SmartScroller",
  "version": "0.2.0",
  "description": "Keep useful knowledge in your feed and blur low-signal hype, engagement bait, and off-topic posts with local, explainable filtering.",
  "permissions": ["storage", "scripting"],
  "optional_host_permissions": [
    "*://*.youtube.com/*",
    "*://*.instagram.com/*"
  ],
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "SmartScroller"
  },
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "content_scripts": []
}
